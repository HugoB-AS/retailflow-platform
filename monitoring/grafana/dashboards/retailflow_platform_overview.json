{
  "uid": "retailflow-platform-overview",
  "title": "RetailFlow Platform Overview",
  "tags": ["retailflow", "platform", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "FastAPI Up",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "up{job=\"retailflow-fastapi\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PostgreSQL Up",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "pg_up{job=\"retailflow-postgres\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "API Requests / min",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "sum(rate(http_requests_total[1m])) * 60"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PostgreSQL Connections",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "sum(pg_stat_activity_count{job=\"retailflow-postgres\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Requests by Endpoint",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "sum by (handler) (rate(http_requests_total[1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency p95",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL Active Connections",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "sum by (datname) (pg_stat_activity_count{job=\"retailflow-postgres\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL Database Size",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "pg_database_size_bytes{job=\"retailflow-postgres\", datname=\"retailflow_db\"}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prometheus Targets Up",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "up"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "RetailFlow Prometheus"},
          "expr": "sum by (status) (rate(http_requests_total[1m]))"
        }
      ]
    }
  ]
}
