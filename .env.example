# ============================================================
# RetailFlow Platform - Example environment configuration
# ============================================================
# Copy this file to ".env" for local customization.
# Do not commit real production secrets in Git.

# ------------------------------------------------------------
# Project
# ------------------------------------------------------------
COMPOSE_PROJECT_NAME=retailflow
ENVIRONMENT=local

# ------------------------------------------------------------
# PostgreSQL - RetailFlow application database
# ------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=retailflow_db
POSTGRES_USER=retailflow
POSTGRES_PASSWORD=retailflow

DATABASE_URL=postgresql+psycopg2://retailflow:retailflow@postgres:5432/retailflow_db
AIRFLOW_CONN_RETAILFLOW_POSTGRES=postgresql://retailflow:retailflow@postgres:5432/retailflow_db

# ------------------------------------------------------------
# PostgreSQL - Airflow metadata database
# ------------------------------------------------------------
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_DATABASE_URL=postgresql+psycopg2://airflow:airflow@airflow_postgres:5432/airflow

# ------------------------------------------------------------
# pgAdmin
# ------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@retailflow.com
PGADMIN_DEFAULT_PASSWORD=admin

# ------------------------------------------------------------
# Redpanda / Kafka
# ------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:19092
EVENT_TOPIC=retailflow_events

# ------------------------------------------------------------
# FastAPI
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://fastapi:8000

# ------------------------------------------------------------
# Streamlit
# ------------------------------------------------------------
STREAMLIT_PORT=8501

# ------------------------------------------------------------
# Airflow
# ------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@retailflow.local

# Empty in local demo only.
# In production, this must be generated securely.
AIRFLOW__CORE__FERNET_KEY=

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
POSTGRES_EXPORTER_PORT=9187

# ------------------------------------------------------------
# Pipeline producer demo
# ------------------------------------------------------------
EVENT_COUNT=20
EVENT_DELAY_SECONDS=0.3
PIPELINE_REPORT_DIR=pipeline/reports

# ------------------------------------------------------------
# Backup / restore scripts
# ------------------------------------------------------------
BACKUP_DIR=backups/postgres
BACKUP_RETENTION_DAYS=7
